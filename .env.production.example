# Copy to .env.production and fill in real values
# Do NOT commit .env.production — it is git-ignored

ENVIRONMENT=production
DEBUG=false

# Database — replace with your RDS endpoint
DATABASE_URL=postgresql://DB_USER:DB_PASSWORD@YOUR-RDS-ENDPOINT:5432/jobqueue

# Authentication — use a strong random string
SECRET_KEY=replace-with-strong-random-secret

# AWS
AWS_REGION=ap-south-1
AWS_ACCOUNT_ID=your-aws-account-id

# SQS
QUEUE_TYPE=sqs
SQS_QUEUE_URL=https://sqs.ap-south-1.amazonaws.com/YOUR_ACCOUNT_ID/job-queue-tasks-production
SQS_DLQ_URL=https://sqs.ap-south-1.amazonaws.com/YOUR_ACCOUNT_ID/job-queue-dlq-production

# Lambda
IS_LAMBDA=true
LAMBDA_TASK_ROOT=/var/task
