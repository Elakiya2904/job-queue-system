# Copy this file to .env and fill in your values
# Do NOT commit .env — it is git-ignored

# Authentication
SECRET_KEY=change-this-to-a-random-32-char-string

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/job_queue

# Worker log level
WORKER_LOG_LEVEL=info

# AWS credentials (for local development only — use IAM roles in production)
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_REGION=ap-south-1
